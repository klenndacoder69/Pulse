# Copy this file to .env and fill in your values
# cp .env.example .env

# Postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=telemetry

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me

# Services (internal Docker network hostnames — keep as-is for Docker Compose)
REDIS_HOST=redis-cache
DB_HOST=postgres-db

# Pulse agent ingest endpoint
# Used for local native testing; when running via docker-compose, this is overridden automatically
API_URL=http://localhost:8080/ingest
